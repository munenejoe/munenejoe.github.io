          <div>HANDLE &nbsp;<span class="cr">@munenejoe</span></div>
          <div>SIGNAL &nbsp;<span class="hl">OPEN</span></div>
        </div>
      </div>

      <div class="contact-right">
        <a href="https://github.com/munenejoe" target="_blank" rel="noopener" class="contact-link">
          <span>[ GH ]</span>
          <span>github.com/munenejoe</span>
          <span class="contact-link__arrow">→</span>
        </a>
        <a href="mailto:joe@example.com" class="contact-link">
          <span>[ ML ]</span>
          <span>Signal via Email</span>
          <span class="contact-link__arrow">→</span>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="contact-link">
          <span>[ LI ]</span>
          <span>LinkedIn Profile</span>
          <span class="contact-link__arrow">→</span>
        </a>
      </div>
    </section>

  </main>

  <footer class="footer-sig" aria-label="Footer">
    <span>JMM // SIG-INTEL PORTFOLIO // BUILD {buildTime}</span>
    <span>ASTRO + STATIC DEPLOY // GITHUB API{calyx.live ? ' LIVE' : ' FALLBACK'}</span>
    <span>© {new Date().getFullYear()} JOE MUNENE METHA</span>
  </footer>

</Layout>