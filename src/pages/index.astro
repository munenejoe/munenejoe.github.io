            </p>
          </div>

        </div>
      </div>

      <div class="experience-col">
        <div class="section-tag" style="margin-bottom: 1rem;">Intel Report // Capabilities</div>
        <h2 class="col-header">Field<br />Intel</h2>

        <div class="panel panel--ghost" style="margin-bottom: 1.5rem;">
          <div class="panel__header">
            <span>Infrastructure Record</span>
            <span class="status-dot status-dot--ok"></span>
          </div>
          <div class="data-row"><span class="data-row__key">SERVER_UPTIME</span><span class="data-row__val">99.0%</span></div>
          <div class="data-row"><span class="data-row__key">ALERT_LATENCY</span><span class="data-row__val">&lt; 30s</span></div>
          <div class="data-row"><span class="data-row__key">PIPELINE_TYPE</span><span class="data-row__val">Real-time SIEM</span></div>
          <div class="data-row"><span class="data-row__key">CLOUD_ENV</span><span class="data-row__val">GCP / GKE</span></div>
          <div class="data-row"><span class="data-row__key">CONTAINER_ORCH</span><span class="data-row__val">Kubernetes</span></div>
          <div class="data-row"><span class="data-row__key">CONFIG_MGMT</span><span class="data-row__val">Ansible</span></div>
        </div>

        <div class="panel panel--ghost">
          <div class="panel__header">
            <span>Security Posture</span>
            <span class="status-dot"></span>
          </div>
          <div class="data-row"><span class="data-row__key">SIEM_PLATFORM</span><span class="data-row__val">MS Sentinel</span></div>
          <div class="data-row"><span class="data-row__key">THREAT_MODEL</span><span class="data-row__val">Zero-day / Behavioural</span></div>
          <div class="data-row"><span class="data-row__key">DETECTION_LAYERS</span><span class="data-row__val">5 (Octopie)</span></div>
          <div class="data-row"><span class="data-row__key">ANOMALY_ENGINE</span><span class="data-row__val">One-Class SVM</span></div>
          <div class="data-row"><span class="data-row__key">ENDPOINT_COVERAGE</span><span class="data-row__val">Full stack</span></div>
        </div>
