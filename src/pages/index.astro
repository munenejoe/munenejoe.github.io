---

import Layout from '../layouts/Layout.astro';

import { base } from '../lib/base';

interface Repo {
  name: string;
  stargazers_count: number;
  language: string | null;
  html_url: string;
  description: string | null;
  updated_at: string;
}

interface ProjectData {
  stars: number;
  language: string;
  url: string;
  live: boolean;
}

const FALLBACK: Record<string, ProjectData> = {
  calyx: {
    stars: 0,
    language: 'Python',
    url: 'https://github.com/munenejoe/calyx-io',
    live: false,
  },
  octopie: {
    stars: 0,
    language: 'Python',
    url: 'https://github.com/munenejoe/octopie',
    live: false,
  },
};

const projects: Record<string, ProjectData> = { ...FALLBACK };

try {
  const res = await fetch(
    'https://api.github.com/users/munenejoe/repos?sort=updated&per_page=10',
    { headers: { 'Accept': 'application/vnd.github.v3+json' } }
  );
  if (res.ok) {
    const repos: Repo[] = await res.json();
    for (const repo of repos) {
      const key = repo.name.toLowerCase();
      if (key === 'calyx' || key === 'octopie') {
        projects[key] = {
          stars: repo.stargazers_count,
          language: repo.language ?? 'Unknown',
          url: repo.html_url,
          live: true,
        };
      }
    }
  }
} catch (_) {}

const calyx = projects['calyx'];
const octopie = projects['octopie'];

const buildTime = new Date().toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
---

<Layout title="JMM // Signal Intelligence — Joe Munene Metha">

  <!-- NAV -->
  <nav class="nav" aria-label="Primary navigation">
    <div class="nav__logo">JMM<span>//</span>SIG</div>
    <ul class="nav__links">
      <li><a href="#skills">Arsenal</a></li>
      <li><a href="#projects">Systems</a></li>
      <li><a href="#experience">Ops Log</a></li>
      <li><a href="#contact">Uplink</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" aria-label="Hero">
    <div class="hero__left slash-bg">
      <p class="hero__kicker">▸ SIG-INTEL // AUTONOMOUS SYSTEMS // CYBER-DEFENCE</p>
      
      <!-- Identity Block: Hard-capped height prevents layout blowout -->
      <div style="display: flex; align-items: stretch; gap: 1.75rem; margin-top: 1rem; margin-bottom: 1.5rem; height: 13rem; max-width: 100%;">
        
        <!-- 9:16 Aspect Ratio Photo Frame -->
        <div style="aspect-ratio: 9 / 16; border: 2px solid var(--sepia-mid); background-color: var(--ink-black); overflow: hidden; flex-shrink: 0; min-height: 0;">
          <img 
            src={base + 'profile.png'} 
            alt="Joe Munene Metha Profile" 
            style="width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(100%) contrast(125%);"
            loading="eager"
          />
        </div>

        <!-- Main Name Heading -->
        <h1 class="hero__name" style="margin: 0; display: flex; flex-direction: column; justify-content: space-between; line-height: 0.9; height: 100%;">
          <span>Joe</span>
          <span class="hero__name--accent">Munene</span>
          <span>Metha</span>
        </h1>
        
      </div>

      <p class="hero__role">Signal Intelligence & Autonomous Systems Engineer</p>
      </blockquote>
    </div>

    <div class="hero__right">
      <div class="hero__telemetry" aria-label="System telemetry readout">
        <div>IDENT_TAG &nbsp;&nbsp;<span class="hl">JOE-MUNENE-METHA</span></div>
        <div>CLEARANCE &nbsp;<span class="cr">SYSTEMS-ARCHITECT</span></div>
        <div>DOMAIN &nbsp;&nbsp;&nbsp;<span class="hl">CYBERSECURITY / DEVOPS / IOT</span></div>
        <div>ORIGIN &nbsp;&nbsp;&nbsp;<span class="hl">NAIROBI, KE</span></div>
        <div>STATUS &nbsp;&nbsp;&nbsp;<span class="cr">▸ ACTIVE</span></div>
        <div>BUILD &nbsp;&nbsp;&nbsp;&nbsp;<span class="hl">{buildTime}</span></div>
        <div>UPTIME &nbsp;&nbsp;&nbsp;<span class="hl">99%</span> <span class="cr">// VERIFIED INFRA</span></div>
      </div>

      <div style="margin-top: 3rem;">
        <div class="section-tag" style="margin-bottom: 1rem;">Core Metrics</div>
        <div class="data-row"><span class="data-row__key">SERVERS_MAINTAINED</span><span class="data-row__val">99% uptime</span></div>
        <div class="data-row"><span class="data-row__key">ALERT_PIPELINES_BUILT</span><span class="data-row__val">Real-time SIEM</span></div>
        <div class="data-row"><span class="data-row__key">MODELS_DEPLOYED</span><span class="data-row__val">CV + ML Antimalware</span></div>
        <div class="data-row"><span class="data-row__key">CLOUD_PROVIDER</span><span class="data-row__val">GCP / GKE</span></div>
        <div class="data-row"><span class="data-row__key">EDUCATION</span><span class="data-row__val">BSc IT — JKUAT 2021</span></div>
      </div>

      <div class="hero__large-num" aria-hidden="true">JMM</div>
    </div>
  </section>

  <!-- DIAGONAL RULE -->
  <div class="diag-rule" aria-hidden="true"></div>

  <main class="content-wrapper">

    <!-- SKILLS -->
    <section id="skills" class="skills-section" aria-label="Skills">
      <div class="skills-grid">
        <div class="section-tag" style="margin-bottom: 1rem;">Arsenal // Technical Stack</div>
        <h2 class="skills-header">
          Weapon<br />Systems
        </h2>
        <div class="skill-clusters">
          <div>
            <div class="skill-cluster__label">Core Languages</div>
            <div class="skill-tags">
              <span class="skill-tag">Node.js</span>
              <span class="skill-tag">TypeScript</span>
              <span class="skill-tag">Python</span>
              <span class="skill-tag">Bash</span>
            </div>
          </div>
          <div>
            <div class="skill-cluster__label">Frameworks</div>
            <div class="skill-tags">
              <span class="skill-tag">FastAPI</span>
              <span class="skill-tag">Express</span>
              <span class="skill-tag">OpenCV</span>
              <span class="skill-tag">PlantCV</span>
            </div>
          </div>
          <div>
            <div class="skill-cluster__label">Infrastructure</div>
            <div class="skill-tags">
              <span class="skill-tag">GCP</span>
              <span class="skill-tag">GKE</span>
              <span class="skill-tag">Kubernetes</span>
              <span class="skill-tag">Docker</span>
              <span class="skill-tag">Ansible</span>
            </div>
          </div>
          <div>
            <div class="skill-cluster__label">Intelligence / Data</div>
            <div class="skill-tags">
              <span class="skill-tag">MS Sentinel</span>
              <span class="skill-tag">SIEM</span>
              <span class="skill-tag">One-Class SVM</span>
              <span class="skill-tag">PostgreSQL</span>
            </div>
          </div>
        </div>
      </div>

      <div class="skills-aside">
        <div class="skills-aside__title">Proficiency Index</div>

        <div style="margin-bottom: 1.5rem;">
          {[
            { name: 'Python / FastAPI', pct: 90 },
            { name: 'Docker / K8s', pct: 85 },
            { name: 'Node.js / TS', pct: 82 },
            { name: 'GCP / GKE', pct: 78 },
            { name: 'SIEM / Sentinel', pct: 80 },
            { name: 'OpenCV / CV', pct: 75 },
            { name: 'Ansible', pct: 72 },
            { name: 'PostgreSQL', pct: 80 },
          ].map(s => (
            <div class="skill-bar">
              <span class="skill-bar__label">{s.name}</span>
              <span class="skill-bar__value">{s.pct}%</span>
              <div class="skill-bar__track" style="grid-column: 1 / -1;">
                <div class="skill-bar__fill" style={`width: ${s.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <div class="section-tag" style="margin-top: 2rem; margin-bottom: 0.75rem;">Disciplines</div>
        <div class="data-row"><span class="data-row__key">Cybersecurity</span><span class="data-row__val cr" style="color:var(--hollow-crimson)">▸ ACTIVE</span></div>
        <div class="data-row"><span class="data-row__key">DevOps / SRE</span><span class="data-row__val cr" style="color:var(--hollow-crimson)">▸ ACTIVE</span></div>
        <div class="data-row"><span class="data-row__key">IoT / Edge AI</span><span class="data-row__val cr" style="color:var(--hollow-crimson)">▸ ACTIVE</span></div>
        <div class="data-row"><span class="data-row__key">ML Engineering</span><span class="data-row__val">▸ DEPLOYED</span></div>
        <div class="data-row"><span class="data-row__key">GIS / Mapping</span><span class="data-row__val">▸ LEGACY</span></div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="projects-section" aria-label="Projects">
      <div class="projects-header-band">
        <h2>Deployed Systems</h2>
        <span class="meta">
          <span class="status-dot"></span>&nbsp;
          {calyx.live && octopie.live ? 'GITHUB SYNC: LIVE' : 'GITHUB SYNC: STATIC FALLBACK'}
        </span>
      </div>

      <div class="projects-grid">

        <!-- CALYX -->
        <article class="project-card">
          <div class="project-card__body">
            <div class="section-tag" style="margin-bottom: 0.75rem;">Project // SYS-001</div>
            <div class="project-card__name">Calyx</div>
            <div class="project-card__sub">Edge CV Engine // Real-Time Semantic Segmentation</div>
            <p class="project-card__desc">
              Autonomous computer vision engine designed for edge deployment. Combines OpenCV
              and PlantCV pipelines with a One-Class SVM anomaly detector to deliver
              real-time semantic segmentation under constrained compute. Built for
              agricultural intelligence at the network boundary.
            </p>
            <div class="project-card__meta">
              <div class="project-card__stat">
                <strong>{calyx.stars}</strong>
                STARS
              </div>
              <div class="project-card__stat">
                <strong>{calyx.language}</strong>
                LANGUAGE
              </div>
              <div class="project-card__stat">
                <strong>EDGE</strong>
                DEPLOY TARGET
              </div>
              <div class="project-card__stat">
                <strong>SVM</strong>
                ANOMALY MODEL
              </div>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:1rem;">
              <span class="skill-tag">Python</span>
              <span class="skill-tag">OpenCV</span>
              <span class="skill-tag">PlantCV</span>
              <span class="skill-tag">One-Class SVM</span>
              <span class="skill-tag">FastAPI</span>
            </div>
            <a href={calyx.url} target="_blank" rel="noopener" class="project-card__link">
              View Repository →
            </a>
          </div>
        </article>

        <!-- OCTOPIE -->
        <article class="project-card">
          <div class="project-card__body">
            <div class="section-tag" style="margin-bottom: 0.75rem;">Project // SYS-002</div>
            <div class="project-card__name">Octopie</div>
            <div class="project-card__sub">Neural Defence Architect // 5-Layer Bio-Inspired ML Antimalware</div>
            <p class="project-card__desc">
              Bio-inspired multi-layer antimalware engine modelled on cephalopod
